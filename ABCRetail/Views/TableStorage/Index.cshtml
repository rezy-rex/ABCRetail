@using ABCRetail.Models
@{
    ViewData["Title"] = "Table Storage";
    var customers = ViewBag.Customers as List<CustomerEntity> ?? new();
    var products = ViewBag.Products as List<ProductEntity> ?? new();
}

<div class="tab-bar">
    <button class="tab active" onclick="showTab('customers', this)">Customers <span class="badge">@customers.Count</span></button>
    <button class="tab" onclick="showTab('products', this)">Products <span class="badge">@products.Count</span></button>
</div>

<!-- Customers Tab -->
<div id="tab-customers" class="tab-content">
    <div class="two-col">
        <div class="card">
            <div class="card-header">Add Customer Record</div>
            <form method="post" action="/TableStorage/AddCustomer">
                <div class="form-group"><label>First Name</label><input name="FirstName" placeholder="e.g. Thabelo" required /></div>
                <div class="form-group"><label>Last Name</label><input name="LastName" placeholder="e.g. Mukwevho" required /></div>
                <div class="form-group"><label>Email</label><input name="Email" type="email" placeholder="thabelo@example.co.za" required /></div>
                <div class="form-group"><label>Phone</label><input name="Phone" placeholder="+27 XX XXX XXXX" /></div>
                <div class="form-group"><label>Address</label><input name="Address" placeholder="123 Main Rd, Johannesburg" /></div>
                <button type="submit" class="btn btn-primary">Save Customer</button>
            </form>
        </div>
        <div class="card">
            <div class="card-header">Customer Registry <span class="badge">@customers.Count</span></div>
            @if (!customers.Any())
            {
                <div class="empty-state">No customer records found. Add one using the form.</div>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Full Name</th><th>Email</th><th>Phone</th><th>Address</th><th style="width: 60px;">Actions</th></tr></thead>
                        <tbody>
                            @foreach (var c in customers)
                            {
                                <tr>
                                    <td><strong>@c.FirstName @c.LastName</strong></td>
                                    <td>@c.Email</td>
                                    <td>@c.Phone</td>
                                    <td>@c.Address</td>
                                    <td>
                                        <form method="post" action="/TableStorage/DeleteCustomer">
                                            <input type="hidden" name="partitionKey" value="@c.PartitionKey" />
                                            <input type="hidden" name="rowKey" value="@c.RowKey" />
                                            <button type="submit" class="btn btn-danger btn-sm" title="Delete Record">✕</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Products Tab -->
<div id="tab-products" class="tab-content" style="display:none">
    <div class="two-col">
        <div class="card">
            <div class="card-header">Add Product Record</div>
            <form method="post" action="/TableStorage/AddProduct">
                <div class="form-group"><label>Product Name</label><input name="ProductName" placeholder="e.g. Wireless Keyboard" required /></div>
                <div class="form-group"><label>Category</label><input name="Category" placeholder="e.g. Peripherals" required /></div>
                <div class="form-group"><label>Price (R)</label><input name="Price" type="number" step="0.01" placeholder="0.00" required /></div>
                <div class="form-group"><label>Stock</label><input name="Stock" type="number" placeholder="0" required /></div>
                <div class="form-group"><label>Description</label><input name="Description" placeholder="Brief product specifications..." /></div>
                <button type="submit" class="btn btn-primary">Save Product</button>
            </form>
        </div>
        <div class="card">
            <div class="card-header">Product Inventory <span class="badge">@products.Count</span></div>
            @if (!products.Any())
            {
                <div class="empty-state">No product records found. Add one using the form.</div>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th style="width: 60px;">Actions</th></tr></thead>
                        <tbody>
                            @foreach (var p in products)
                            {
                                <tr>
                                    <td><strong>@p.ProductName</strong></td>
                                    <td>@p.Category</td>
                                    <td>R @p.Price.ToString("F2")</td>
                                    <td>@p.Stock</td>
                                    <td>
                                        <form method="post" action="/TableStorage/DeleteProduct">
                                            <input type="hidden" name="partitionKey" value="@p.PartitionKey" />
                                            <input type="hidden" name="rowKey" value="@p.RowKey" />
                                            <button type="submit" class="btn btn-danger btn-sm" title="Delete Record">✕</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function showTab(tabName, btn) {
        document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
        document.getElementById('tab-' + tabName).style.display = 'block';
        btn.classList.add('active');
    }
</script>